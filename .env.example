

WEBHOOK_HMAC_SECRET=change_me_min_32_chars_xxxxxxxxxx

# ── Backend URL (local sur VPS mono-machine) ────────────────
BACKEND_WEBHOOK_URL=http://localhost:8000/signal

# ── MetaTrader 5 (détecteur) ────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Demo

# ── Symbole et scan ─────────────────────────────────────────
SYMBOL=XAUUSD
SCAN_INTERVAL_SECONDS=30
ENABLED_TIERS=S,A,B
ENABLED_KILLZONES=LONDON,NY_AM,NY_PM
TIMEZONE=Africa/Casablanca

# ── LLM (Groq) ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_key
LLM_TIMEOUT_SECONDS=5

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-token
TELEGRAM_CHAT_ID=123456789

# ── News ────────────────────────────────────────────────────
NEWS_REFRESH_MINUTES=5
NEWS_RED_BLOCK_WINDOW_MIN=15
# Mettre true pour bloquer aussi les news orange USD (±5min)
BLOCK_ORANGE_NEWS=false
NEWS_ORANGE_BLOCK_WINDOW_MIN=5

# ── Base de données ─────────────────────────────────────────
DATABASE_URL=sqlite:///./alerts.db

# ── Logs ────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000
API_SECRET_TOKEN=change_me_for_get_endpoints
